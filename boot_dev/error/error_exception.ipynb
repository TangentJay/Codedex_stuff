    "# Errors and Exceptions in Python\n",
    "july 20 2026"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "7f44dedc",
   "metadata": {},
   "source": [
    "try:\n",
    "  10 / 0\n",
    "except Exception:\n",
    "  print(\"can't divide by zero\")"
   ]
  },
  {
   "cell_type": "code",
