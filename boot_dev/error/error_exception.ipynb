   "source": [
    "# try-except\n",
    "#f we want to access the data from the exception, we use the following syntax:\n",
    "try:\n",
    "  10 / 0\n",
    "except Exception as e:\n",
    "  print(e)\n",
    "\n",
    "# prints \"division by zero\""
   ]
